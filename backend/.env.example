# GeoEnergy Intelligence AI — Backend Environment Variables
# Copy this file to .env and fill in your own API keys.
# NEVER commit .env to source control.

# ── Market Prices ──────────────────────────────────────────────────────────────
# Alpha Vantage (free tier) — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# EIA Open Data API (free) — https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── News / Headlines ──────────────────────────────────────────────────────────
# The Guardian API (free) — https://open-platform.theguardian.com
GUARDIAN_API_KEY=

# NewsAPI (free dev tier) — https://newsapi.org/register
NEWS_API_KEY=

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API (free) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq API (free — Llama 3) — https://console.groq.com
GROQ_API_KEY=

# OpenAI API (optional fallback) — https://platform.openai.com/
OPENAI_API_KEY=
